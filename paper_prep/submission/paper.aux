\@writefile{toc}{\contentsline {section}{\numberline {1}Extended Data Figure Legends}{31}{section.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {ED1}{\ignorespaces \textbf  {Pipeline schematic, per-arm flank counts, PHR length distribution, chr18q chimera control.} \textbf  {(a)} Pipeline overview: 465 HPRCv2 v1.1 haplotype assemblies (233 individuals) $\to $ 18,827 telomere-anchored 500 kb subtelomeric flanks across 48 arms $\to $ wfmash all-vs-all $-p\ 95\ -t\ 48$ (18,827 PAFs) $\to $ impg sliding-window scan (id $\geq 0.95$, $\geq 2$ chrs, $\geq 5$ alns/chr, $\geq 3$ kb output) $\to $ 15,668 PHRs (83.2\%) $\to $ pggb + odgi similarity ($15668 \times 15668$ Jaccard) $\to $ Leiden 15 arm-level (silhouette 0.347) and 50 sequence-level (modularity 0.97). \textbf  {(b)} Per-arm flank counts ($n = 18826$ flanks across 48 arms; median 447/arm). Acrocentric p (chr13\_p 76 to chr22\_p 223) and sex chromosomes (chrY\_p 92 to chrX\_q 330) are systematically under-represented. \textbf  {(c)} PHR length distribution for the 15,668 signal-bearing flanks (median 105 kb, mean 144 kb; saturates at 500 kb because input flanks are clipped). \textbf  {(d)} Chr18\_q chimera (NA18982\#1, JBKABS010000018.1, 84.4 Mb): 966 kb of chrX PAR1 fused to the chr18 backbone across a 100 bp NNN scaffold join at $\approx $83.37 Mb; mapq 60 in both wfmash v0.23 and minimap2 v2.30; 2,826 bp (TTAGGG)$_n \times 471$ precedes the gap. Removed from the PHR set (15,669 $\to $ 15,668).}}{31}{figure.caption.36}\protected@file@percent }
\newlabel{fig:ed1}{{ED1}{31}{\textbf {Pipeline schematic, per-arm flank counts, PHR length distribution, chr18q chimera control.} \textbf {(a)} Pipeline overview: 465 HPRCv2 v1.1 haplotype assemblies (233 individuals) $\to $ 18,827 telomere-anchored 500 kb subtelomeric flanks across 48 arms $\to $ wfmash all-vs-all $-p\ 95\ -t\ 48$ (18,827 PAFs) $\to $ impg sliding-window scan (id $\geq 0.95$, $\geq 2$ chrs, $\geq 5$ alns/chr, $\geq 3$ kb output) $\to $ 15,668 PHRs (83.2\%) $\to $ pggb + odgi similarity ($15668 \times 15668$ Jaccard) $\to $ Leiden 15 arm-level (silhouette 0.347) and 50 sequence-level (modularity 0.97). \textbf {(b)} Per-arm flank counts ($n = 18826$ flanks across 48 arms; median 447/arm). Acrocentric p (chr13\_p 76 to chr22\_p 223) and sex chromosomes (chrY\_p 92 to chrX\_q 330) are systematically under-represented. \textbf {(c)} PHR length distribution for the 15,668 signal-bearing flanks (median 105 kb, mean 144 kb; saturates at 500 kb because input flanks are clipped). \textbf {(d)} Chr18\_q chimera (NA18982\#1, JBKABS010000018.1, 84.4 Mb): 966 kb of chrX PAR1 fused to the chr18 backbone across a 100 bp NNN scaffold join at $\approx $83.37 Mb; mapq 60 in both wfmash v0.23 and minimap2 v2.30; 2,826 bp (TTAGGG)$_n \times 471$ precedes the gap. Removed from the PHR set (15,669 $\to $ 15,668)}{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED2}{\ignorespaces \textbf  {Sequence-level (50-community) detail.} \textbf  {(a)} UMAP layout of all 15,668 PHRs, coloured by sequence-level Leiden community (50; $k = 75$, res $= 0.8$, modularity 0.97). \textbf  {(b)} Within-community Jaccard distance distributions for the 8 arm-level communities flagged as bimodal (C1, C2, C3, C5, C6, C7, C11, C12). Allele/paralog separation is visible in C5, C7, C11. \textbf  {(c)} Cross-arm affinity radial plot. 2,484 cross-arm sequences $\to $ 48 (origin $\to $ affinity) edges between 41 partition arms; chord width $\propto \sqrt  {\#\mathrm  {sequences}}$; chord hue = arm-Leiden community of the destination. Top edges: chrY\_q$\to $chrX\_q 329 (PAR2), chrY\_p$\to $chrX\_p 287 (PAR1), chr15\_p$\to $chr14\_p 280, chr10\_q$\to $chr4\_q 220 (D4Z4). \textbf  {(d)} Confusion matrix between the arm-Leiden (15 rows) and seq-Leiden (50 cols) partitions; cell colour $= \#$PHRs (sqrt). ARI 0.35, NMI 0.76, $n = 15668$. C3 and C11 are the most fragmented; C1 (D4Z4) is the most monolithic.}}{32}{figure.caption.37}\protected@file@percent }
\newlabel{fig:ed2}{{ED2}{32}{\textbf {Sequence-level (50-community) detail.} \textbf {(a)} UMAP layout of all 15,668 PHRs, coloured by sequence-level Leiden community (50; $k = 75$, res $= 0.8$, modularity 0.97). \textbf {(b)} Within-community Jaccard distance distributions for the 8 arm-level communities flagged as bimodal (C1, C2, C3, C5, C6, C7, C11, C12). Allele/paralog separation is visible in C5, C7, C11. \textbf {(c)} Cross-arm affinity radial plot. 2,484 cross-arm sequences $\to $ 48 (origin $\to $ affinity) edges between 41 partition arms; chord width $\propto \sqrt {\#\mathrm {sequences}}$; chord hue = arm-Leiden community of the destination. Top edges: chrY\_q$\to $chrX\_q 329 (PAR2), chrY\_p$\to $chrX\_p 287 (PAR1), chr15\_p$\to $chr14\_p 280, chr10\_q$\to $chr4\_q 220 (D4Z4). \textbf {(d)} Confusion matrix between the arm-Leiden (15 rows) and seq-Leiden (50 cols) partitions; cell colour $= \#$PHRs (sqrt). ARI 0.35, NMI 0.76, $n = 15668$. C3 and C11 are the most fragmented; C1 (D4Z4) is the most monolithic}{figure.caption.37}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED3}{\ignorespaces \textbf  {Annotation: TAR1, internal (TTAGGG)$_n$ islands, telomere length.} \textbf  {(a)} TAR1 prevalence per arm. Bars show the percentage of haplotypes carrying $\geq $1 TAR1 entry on each of 41 chromosome arms ($n = 14816$ of 15,668 sequences with TAR1; 94.6\%). PAR1 arms (chrXp 0.3\%, chrYp 1.1\%) are TAR1-free; acrocentric p-arms (chr13p--chr22p) sit at 73--79\%; autosomal arms saturate at $>99\%$. \textbf  {(b)} (TTAGGG)$_n$ island length and motif composition. Length-bin histogram of 18,352 internal (TTAGGG)$_n$ islands across 8,321 sequences (53.1\% of PHR sequences). \textbf  {(c)} Terminal telomere length by community. Per-community medians $\pm $ mean SD, ordered by median. Range 7,638 bp (C10/chr17p) to 9,418 bp (C13/chr4p). Kruskal-Wallis $H = 100.89$, $p = 3.2 \times 10^{-15}$ across 13,668 sequences in 15 communities. \textbf  {(d)} Per-arm TAR1 distance-from-telomere (median, $\log _{10}$ kb). Most arms place TAR1 within 1 kb of telomere; acrocentric p-arms (179--196 kb) and chr9q (223 kb) carry the deepest TAR1.}}{33}{figure.caption.38}\protected@file@percent }
\newlabel{fig:ed3}{{ED3}{33}{\textbf {Annotation: TAR1, internal (TTAGGG)$_n$ islands, telomere length.} \textbf {(a)} TAR1 prevalence per arm. Bars show the percentage of haplotypes carrying $\geq $1 TAR1 entry on each of 41 chromosome arms ($n = 14816$ of 15,668 sequences with TAR1; 94.6\%). PAR1 arms (chrXp 0.3\%, chrYp 1.1\%) are TAR1-free; acrocentric p-arms (chr13p--chr22p) sit at 73--79\%; autosomal arms saturate at $>99\%$. \textbf {(b)} (TTAGGG)$_n$ island length and motif composition. Length-bin histogram of 18,352 internal (TTAGGG)$_n$ islands across 8,321 sequences (53.1\% of PHR sequences). \textbf {(c)} Terminal telomere length by community. Per-community medians $\pm $ mean SD, ordered by median. Range 7,638 bp (C10/chr17p) to 9,418 bp (C13/chr4p). Kruskal-Wallis $H = 100.89$, $p = 3.2 \times 10^{-15}$ across 13,668 sequences in 15 communities. \textbf {(d)} Per-arm TAR1 distance-from-telomere (median, $\log _{10}$ kb). Most arms place TAR1 within 1 kb of telomere; acrocentric p-arms (179--196 kb) and chr9q (223 kb) carry the deepest TAR1}{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED4}{\ignorespaces \textbf  {Gene enrichment, copy-weighted GO, pseudogene gradient.} \textbf  {(a)} GO:BP top terms (PHR-only gene set, $n = 23$ protein-coding genes). Top 10 GO Biological Process terms ranked by adjusted $p$-value (gprofiler ORA). Spliceosome / snRNP terms dominate the list. \textbf  {(b)} Copy-weighted vs deduplicated GO enrichment. \textbf  {(c)} High-copy gene families (top 15, coding + pseudogene). Copy count across PHRs for the 15 highest-copy protein-coding and pseudogene families. \textbf  {(d)} OR4F pseudogenisation gradient by arm. Pseudogene fraction of OR4F annotations per arm ($n = 5023$ entries across 16 arms). Range 11.1\% (chr7p) to 99.8\% (chr15q); population mean 62.1\%. Sub-nucleolar territories are individually addressable per NOR-containing chromosome via monoallelically-expressed SNUL ncRNAs \cite  {hao2024snul}.}}{34}{figure.caption.39}\protected@file@percent }
\newlabel{fig:ed4}{{ED4}{34}{\textbf {Gene enrichment, copy-weighted GO, pseudogene gradient.} \textbf {(a)} GO:BP top terms (PHR-only gene set, $n = 23$ protein-coding genes). Top 10 GO Biological Process terms ranked by adjusted $p$-value (gprofiler ORA). Spliceosome / snRNP terms dominate the list. \textbf {(b)} Copy-weighted vs deduplicated GO enrichment. \textbf {(c)} High-copy gene families (top 15, coding + pseudogene). Copy count across PHRs for the 15 highest-copy protein-coding and pseudogene families. \textbf {(d)} OR4F pseudogenisation gradient by arm. Pseudogene fraction of OR4F annotations per arm ($n = 5023$ entries across 16 arms). Range 11.1\% (chr7p) to 99.8\% (chr15q); population mean 62.1\%. Sub-nucleolar territories are individually addressable per NOR-containing chromosome via monoallelically-expressed SNUL ncRNAs \cite {hao2024snul}}{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED5}{\ignorespaces \textbf  {Multi-resolution and confound-exclusion robustness for Hi-C.} \textbf  {(a)} W/B contact across five mcool resolutions, eight datasets. Mean inter-chromosomal within-community contact $\div $ mean between. All 40 (sample $\times $ resolution) cells have $W/B \geq 11.6$ (median 18.5, max 48.4). \textbf  {(b)} Mantel $\rho $ before vs after acrocentric+sex exclusion (50 kb). Each point is one HPRC sample ($n = 7$). $Y > X$ for 7/7 --- excluding chr13--22 p-arms and chrX/Y \emph  {strengthens} the arm-similarity $\leftrightarrow $ Hi-C correlation. \textbf  {(c)} O/E-normalised contact, within vs between sequence community. Mean O/E over all \emph  {trans} arm pairs. Within $>$ between by $5.9\times $ to $18.4\times $. \textbf  {(d)} Per-community reproducibility heatmap, 15 sequence communities $\times $ 11 datasets, 50 kb. Cell colour $= \log _2$(\emph  {observed / null mean within-community contact}) from 10,000 random-label permutations; $* q < 0.05$, $** q < 0.001$ (Benjamini-Hochberg).}}{35}{figure.caption.40}\protected@file@percent }
\newlabel{fig:ed5}{{ED5}{35}{\textbf {Multi-resolution and confound-exclusion robustness for Hi-C.} \textbf {(a)} W/B contact across five mcool resolutions, eight datasets. Mean inter-chromosomal within-community contact $\div $ mean between. All 40 (sample $\times $ resolution) cells have $W/B \geq 11.6$ (median 18.5, max 48.4). \textbf {(b)} Mantel $\rho $ before vs after acrocentric+sex exclusion (50 kb). Each point is one HPRC sample ($n = 7$). $Y > X$ for 7/7 --- excluding chr13--22 p-arms and chrX/Y \emph {strengthens} the arm-similarity $\leftrightarrow $ Hi-C correlation. \textbf {(c)} O/E-normalised contact, within vs between sequence community. Mean O/E over all \emph {trans} arm pairs. Within $>$ between by $5.9\times $ to $18.4\times $. \textbf {(d)} Per-community reproducibility heatmap, 15 sequence communities $\times $ 11 datasets, 50 kb. Cell colour $= \log _2$(\emph {observed / null mean within-community contact}) from 10,000 random-label permutations; $* q < 0.05$, $** q < 0.001$ (Benjamini-Hochberg)}{figure.caption.40}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED6}{\ignorespaces \textbf  {Discussion synthesis: feedback loop, D4Z4 model, recombination null, compartment diagnostic.} \textbf  {(a)} Causal feedback loop. Four-link cycle: sequence sharing $\to $ 3D proximity $\to $ ectopic exchange $\to $ new shared segments $\to $ propagation. \textbf  {(b)} D4Z4-CTCF-lamin tethering for C1 (chr4q $\leftrightarrow $ chr10q). D4Z4 macrosatellite at the tip $\to $ CTCF binding $\to $ lamin A/C tether $\to $ co-peripheralisation (Dip-C radial 0.732). \textbf  {(c)} Recombination vs cross-arm affinity --- honest null. Lalli 2025 cM/Mb vs per-arm fraction of sequences in cross-arm communities. Left: all 46 arms, $\rho = -0.35$, $p = 0.017$. Right: well-callable arms only ($>12$ callable variants; $n = 40$), $\rho = -0.01$, $p = 0.97$. Anti-correlation is driven by seven low-callability arms. \textbf  {(d)} Compartment identity at tips (HG002, $n = 92$ arm $\times $ hap). 63/92 = 68\% A-compartment; mean $e_1 = +0.0073$. Loss of zygotene cilia (CEP164 KO) eliminates ciliogenesis without disrupting meiotic chromosome pairing or DSB repair \cite  {bouquet_ChenCEP164Cilia2025}, indicating that the cilium is dispensable for the core meiotic chromosome events while leaving telomere clustering at the nuclear envelope unaddressed.}}{36}{figure.caption.41}\protected@file@percent }
\newlabel{fig:ed6}{{ED6}{36}{\textbf {Discussion synthesis: feedback loop, D4Z4 model, recombination null, compartment diagnostic.} \textbf {(a)} Causal feedback loop. Four-link cycle: sequence sharing $\to $ 3D proximity $\to $ ectopic exchange $\to $ new shared segments $\to $ propagation. \textbf {(b)} D4Z4-CTCF-lamin tethering for C1 (chr4q $\leftrightarrow $ chr10q). D4Z4 macrosatellite at the tip $\to $ CTCF binding $\to $ lamin A/C tether $\to $ co-peripheralisation (Dip-C radial 0.732). \textbf {(c)} Recombination vs cross-arm affinity --- honest null. Lalli 2025 cM/Mb vs per-arm fraction of sequences in cross-arm communities. Left: all 46 arms, $\rho = -0.35$, $p = 0.017$. Right: well-callable arms only ($>12$ callable variants; $n = 40$), $\rho = -0.01$, $p = 0.97$. Anti-correlation is driven by seven low-callability arms. \textbf {(d)} Compartment identity at tips (HG002, $n = 92$ arm $\times $ hap). 63/92 = 68\% A-compartment; mean $e_1 = +0.0073$. Loss of zygotene cilia (CEP164 KO) eliminates ciliogenesis without disrupting meiotic chromosome pairing or DSB repair \cite {bouquet_ChenCEP164Cilia2025}, indicating that the cilium is dispensable for the core meiotic chromosome events while leaving telomere clustering at the nuclear envelope unaddressed}{figure.caption.41}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {ED7}{\ignorespaces \textbf  {Neighbour-joining tree of arm-level Jaccard distances.} Per-named-grouping support from a 1,000-replicate character-level bootstrap (PHRs resampled with replacement): PAR1 100\%, PAR2 100\%, 10p/18p 100\%, 4q/10q 99.4\%, acrocentric p-arms 52\% NJ / 87\% UPGMA; the 6-arm tight q-arm grouping is 0.1\% under the chromosome-granularity surrogate, a data-granularity artefact (see Methods).}}{37}{figure.caption.42}\protected@file@percent }
\newlabel{fig:ed7}{{ED7}{37}{\textbf {Neighbour-joining tree of arm-level Jaccard distances.} Per-named-grouping support from a 1,000-replicate character-level bootstrap (PHRs resampled with replacement): PAR1 100\%, PAR2 100\%, 10p/18p 100\%, 4q/10q 99.4\%, acrocentric p-arms 52\% NJ / 87\% UPGMA; the 6-arm tight q-arm grouping is 0.1\% under the chromosome-granularity surrogate, a data-granularity artefact (see Methods)}{figure.caption.42}{}}
\gdef \@abspage@last{37}
