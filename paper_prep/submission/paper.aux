\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Population-scale subtelomeric communities.} Inter-chromosomal subtelomeric sharing partitions 41 chromosome arms into 15 communities across 465 HPRCv2 haplotypes (18,827 telomere-anchored 500 kb flanks; 15,668 PHRs). \textbf  {(a)} Genome-wide stacked identity heatmap of 465 HPRC v2 haplotypes plus CHM13 across 24 chromosomes in 100 kb windows. Telomere-anchored high-identity blocks mark the inter-chromosomal exchange landscape. \textbf  {(b)} Genome-wide number-of-chromosome-contributors heatmap with PHR-BED overlay. \textbf  {(c)} $41 \times 41$ arm-level Jaccard distance heatmap, arms ordered by Leiden $k = 15$ community, with UPGMA $k = 14$ dendrogram on top. \textbf  {(d)} Per-arm architecture (homogeneous, polymorphic, fully interchangeable) and cross-arm sequence rate.}}{23}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:fig1}{{1}{23}{\textbf {Population-scale subtelomeric communities.} Inter-chromosomal subtelomeric sharing partitions 41 chromosome arms into 15 communities across 465 HPRCv2 haplotypes (18,827 telomere-anchored 500 kb flanks; 15,668 PHRs). \textbf {(a)} Genome-wide stacked identity heatmap of 465 HPRC v2 haplotypes plus CHM13 across 24 chromosomes in 100 kb windows. Telomere-anchored high-identity blocks mark the inter-chromosomal exchange landscape. \textbf {(b)} Genome-wide number-of-chromosome-contributors heatmap with PHR-BED overlay. \textbf {(c)} $41 \times 41$ arm-level Jaccard distance heatmap, arms ordered by Leiden $k = 15$ community, with UPGMA $k = 14$ dendrogram on top. \textbf {(d)} Per-arm architecture (homogeneous, polymorphic, fully interchangeable) and cross-arm sequence rate}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Within-community heterogeneity, two-domain model and population structure.} \textbf  {(a)} Per-community Wilcoxon paired allele-vs-paralog distance. \textbf  {(b)} Per-arm Spearman gradient and piecewise-regression breakpoints for the two-domain model. \textbf  {(c)} Cross-arm superpopulation Fisher enrichment and Hudson $F_{\mathrm  {ST}}$. \textbf  {(d)} UPGMA out-of-Africa tree from the $F_{\mathrm  {ST}}$ matrix (population structure, not subtelomere-specific signature; matched-region control deferred, see Methods \textsection $F_{\mathrm  {ST}}$).}}{24}{figure.caption.9}\protected@file@percent }
\newlabel{fig:fig2}{{2}{24}{\textbf {Within-community heterogeneity, two-domain model and population structure.} \textbf {(a)} Per-community Wilcoxon paired allele-vs-paralog distance. \textbf {(b)} Per-arm Spearman gradient and piecewise-regression breakpoints for the two-domain model. \textbf {(c)} Cross-arm superpopulation Fisher enrichment and Hudson $F_{\mathrm {ST}}$. \textbf {(d)} UPGMA out-of-Africa tree from the $F_{\mathrm {ST}}$ matrix (population structure, not subtelomere-specific signature; matched-region control deferred, see Methods \textsection $F_{\mathrm {ST}}$)}{figure.caption.9}{}}
\newlabel{secMethods}{{2}{24}{Methods}{section*.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Three-dimensional nuclear organisation mirrors sequence communities.} \textbf  {(a)} HG002 Pore-C inter-arm contact at 50 kb, $B/W = 0.056$. \textbf  {(b)} Forest plot of 14 inter-arm 3D tests across Hi-C, Pore-C, CiFi, Dip-C, sperm scHi-C and mouse meiotic Hi-C. \textbf  {(c)} $S_{\mathrm  {all}}$ negative control in GM12878 Dip-C and 20-cell sperm scHi-C. \textbf  {(d)} Flanking paradox: PHR vs flanking 100 kb B/W (with Mantel $\rho $ reported alongside); Dip-C radial inset.}}{25}{figure.caption.10}\protected@file@percent }
\newlabel{fig:fig3}{{3}{25}{\textbf {Three-dimensional nuclear organisation mirrors sequence communities.} \textbf {(a)} HG002 Pore-C inter-arm contact at 50 kb, $B/W = 0.056$. \textbf {(b)} Forest plot of 14 inter-arm 3D tests across Hi-C, Pore-C, CiFi, Dip-C, sperm scHi-C and mouse meiotic Hi-C. \textbf {(c)} $S_{\mathrm {all}}$ negative control in GM12878 Dip-C and 20-cell sperm scHi-C. \textbf {(d)} Flanking paradox: PHR vs flanking 100 kb B/W (with Mantel $\rho $ reported alongside); Dip-C radial inset}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Pedigree-resolved exchanges and cross-species generalisation.} \textbf  {(a)} WashU 3-generation T2T pedigree: 538 high-quality patches, 494 within Leiden communities (Wilson 95\% CI 89.2--93.9\%; Monte Carlo permutation null mean 77.0\%, 95\% CI 75.4--78.8\%, observed $p < 10^{-4}$). \textbf  {(b)} CEPH1463 4-generation pedigree: 11 hifiasm-and-verkko-validated features (observed 100\% within-community; null mean 30.7\%, $p \approx 10^{-4}$). \textbf  {(c)} RPE-1 self: Leiden C2 = \{chr10\_q, chrX\_q\} and elevated CiFi contact. \textbf  {(d)} Mouse zygotene Hi-C vs arm-level Jaccard distance, Mantel $\rho = 0.718$, permutation $p < 1 \times 10^{-4}$, 95\% CI 0.47--0.86 ($n_{\mathrm  {arms}} = 27$).}}{26}{figure.caption.11}\protected@file@percent }
\newlabel{fig:fig4}{{4}{26}{\textbf {Pedigree-resolved exchanges and cross-species generalisation.} \textbf {(a)} WashU 3-generation T2T pedigree: 538 high-quality patches, 494 within Leiden communities (Wilson 95\% CI 89.2--93.9\%; Monte Carlo permutation null mean 77.0\%, 95\% CI 75.4--78.8\%, observed $p < 10^{-4}$). \textbf {(b)} CEPH1463 4-generation pedigree: 11 hifiasm-and-verkko-validated features (observed 100\% within-community; null mean 30.7\%, $p \approx 10^{-4}$). \textbf {(c)} RPE-1 self: Leiden C2 = \{chr10\_q, chrX\_q\} and elevated CiFi contact. \textbf {(d)} Mouse zygotene Hi-C vs arm-level Jaccard distance, Mantel $\rho = 0.718$, permutation $p < 1 \times 10^{-4}$, 95\% CI 0.47--0.86 ($n_{\mathrm {arms}} = 27$)}{figure.caption.11}{}}
